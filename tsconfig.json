{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "moduleResolution": "node",
        "noImplicitAny": true,
        "sourceMap": true,
        "removeComments": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "*": [
                "./typings/*"
            ],
        }
    },
    "include": [
        "src/**/*",
        "typings/**/*"
    ],
    "exclude": [
        "test/**/*"
    ]
}
